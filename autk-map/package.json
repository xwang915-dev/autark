{
  "name": "autk-map",
  "version": "2.0.0",
  "keywords": [
    "visualization",
    "urban",
    "3D"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/autk-map.umd.cjs",
  "module": "./dist/autk-map.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/autk-map.js",
      "require": "./dist/autk-map.umd.cjs"
    }
  },
  "scripts": {
    "doc": "typedoc --options typedoc.json",
    "dev": "vite",
    "dev-build": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/earcut": "^3.0.0",
    "@types/geojson": "^7946.0.16",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "ts-loader": "^9.5.7",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-theme-oxide": "^0.2.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-glsl": "^1.5.6"
  },
  "dependencies": {
    "@turf/turf": "^7.3.4",
    "d3": "^7.9.0",
    "earcut": "^3.0.2",
    "gl-matrix": "^3.4.4",
    "poly-extrude": "^0.22.2"
  }
}
