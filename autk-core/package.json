{
  "name": "@urban-toolkit/autk-core",
  "version": "2.2.0",
  "description": "Shared runtime utilities for the Autark toolkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/urban-toolkit/autark",
    "directory": "autk-core"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/autk-core.umd.cjs",
  "module": "./dist/autk-core.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/autk-core.js",
      "require": "./dist/autk-core.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev-build": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "doc": "typedoc --options typedoc.json"
  },
  "dependencies": {
    "@turf/turf": "^7.3.4",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.0",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "earcut": "^3.0.2",
    "gl-matrix": "^3.4.4",
    "rbush": "^4.0.1"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/earcut": "^3.0.0",
    "@types/geojson": "^7946.0.16",
    "@types/rbush": "^4.0.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-theme-oxide": "^0.2.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  }
}
