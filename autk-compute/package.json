{
  "name": "autk-compute",
  "version": "2.0.0",
  "keywords": [
    "urban",
    "data management",
    "WebGPU"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/autk-compute.umd.cjs",
  "module": "./dist/autk-compute.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/autk-compute.js",
      "require": "./dist/autk-compute.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev-build": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "doc": "typedoc --options typedoc.json"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/rbush": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-theme-oxide": "^0.2.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  }
}
