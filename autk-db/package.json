{
  "name": "autk-db",
  "version": "2.0.0",
  "keywords": [
    "urban",
    "data management"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "module": "./dist/autk-db.js",
  "types": "./dist/src/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "import": "./dist/autk-db.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev-build": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "doc": "typedoc --options typedoc.json"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/rbush": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-theme-oxide": "^0.2.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev42.0",
    "@osmix/pbf": "^0.0.9",
    "@osmix/shared": "^0.0.13",
    "@turf/turf": "^7.3.4",
    "apache-arrow": "^21.1.0",
    "geotiff": "^3.0.5",
    "rbush": "^4.0.1"
  }
}
